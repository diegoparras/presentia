# Motor: "tabfm" (real, baja pesos de HuggingFace) o "fake" (tests/CI, sin pesos).
AUGUR_ENGINE=tabfm
# auto | cpu | cuda
AUGUR_DEVICE=auto
# Palanca velocidad/robustez por defecto (8 rápido, 32 máxima calidad).
AUGUR_N_ESTIMATORS=8
# Token de servicio opcional; si se setea, se exige en el header X-Augur-Token.
AUGUR_TOKEN=
# Límites de tamaño de dataset (envelope de TabFM: hasta ~500 features).
AUGUR_MAX_ROWS=10000
AUGUR_MAX_FEATURES=500
AUGUR_TIMEOUT=120
