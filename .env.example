# ─────────────────────────────────────────────────────────────────────────────
# Presentia — example environment
#
# Copy to .env and set what you need. Nothing here is required to *start*: API
# keys and models can be configured from the Settings UI after the first run.
# The variables below are the ones that matter for a real deployment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Persistence ──────────────────────────────────────────────────────────────
# Everything persistent (presentations, config, login, cost history, datasets,
# generated images, exports, uploads, Mem0 memory) lives under /app_data.
# ALWAYS mount a persistent volume at /app_data — even when using Postgres,
# because images/exports/uploads still land there.

# Relational database. Leave empty for the built-in SQLite (a file inside
# /app_data). For production, point it at Postgres — use the PLAIN scheme, the
# app adds the async driver itself (asyncpg at runtime, psycopg for migrations).
# Append ?sslmode=require if your Postgres enforces TLS.
# DATABASE_URL=postgresql://user:password@host:5432/presentia

# Run Alembic migrations on startup (creates the schema, incl. the fork's
# dataset + llm_usage_events tables). Recommended: true.
MIGRATE_DATABASE_ON_STARTUP=true

# ── Login ────────────────────────────────────────────────────────────────────
# Seed the single-user login instead of the first-run form (optional).
# AUTH_USERNAME=admin
# AUTH_PASSWORD=change-me

# ── Federated SSO with Lockatus (Escriba Suite) ──────────────────────────────
# Leave AUTH_MODE unset (or "local") for Presenton's built-in login. Set it to
# "federado" to sign in through the suite's Lockatus hub (OIDC + PKCE, no secret).
# The issuer must be reachable BY THE SAME URL from the browser and from this
# container: in the suite's local compose that's host.docker.internal; behind
# EasyPanel/a domain, use Lockatus's public URL (e.g. https://lockatus.example.com).
# Register a "presentia" client in Lockatus with this exact redirect URI.
# AUTH_MODE=federado
# LOCKATUS_ISSUER=http://host.docker.internal:8081
# LOCKATUS_CLIENT_ID=presentia
# LOCKATUS_REDIRECT_URI=https://presentia.example.com/api/v1/auth/sso/callback
# SESSION_SECRET=<openssl rand -hex 32>   # signs federated session cookies
# COOKIE_SECURE=true                       # true behind HTTPS

# ── Text model (optional — can also be set in the UI onboarding) ──────────────
# One OpenRouter key unlocks almost the whole model catalog at once.
# LLM=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o
#
# Or a direct provider:
# LLM=anthropic       # openai | anthropic | google | deepseek | ollama | ...
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Local models via Ollama (optional) ───────────────────────────────────────
# In EasyPanel/Swarm use the service's internal hostname, NOT host.docker.internal.
# OLLAMA_URL=http://<project>_ollama:11434
# OLLAMA_MODEL=llama3.1:latest

# ── Semantic memory (Mem0) ───────────────────────────────────────────────────
# On by default. Its LLM inherits OLLAMA_URL automatically; embeddings run
# locally (fastembed) with no external call. Set false to turn it off.
# MEM0_ENABLED=true
# MEM0_LLM_MODEL=llama3.1:latest   # must be pulled in your Ollama

# ── Images (optional — can also be set in the UI) ─────────────────────────────
# IMAGE_PROVIDER=          # gpt-image-1.5 | dall-e-3 | gemini_flash | pexels | pixabay | comfyui
# PEXELS_API_KEY=
# PIXABAY_API_KEY=

# ── Web search / grounding (optional) ────────────────────────────────────────
# WEB_GROUNDING=true
# WEB_SEARCH_PROVIDER=searchgirl   # searchgirl | searxng | tavily | exa | brave | auto
# SEARCHGIRL_BASE_URL=http://<project>_searchgirl:8089
# SEARCHGIRL_API_TOKEN=            # optional Bearer, matches Searchgirl's SEARCHGIRL_MCP_TOKEN

# ── Escriba Suite integrations (all optional, opt-in, fail-safe) ──────────────
# Document parsing with OCR via Escriba (falls back to local parsers if down):
# ESCRIBA_ENABLED=true
# ESCRIBA_URL=http://escriba:8000
# ESCRIBA_API_TOKEN=
#
# PII anonymization before the LLM via Anonimal (fail-closed):
# ANONIMAL_ENABLED=true
# ANONIMAL_URL=http://anonimal:8000
# ANONIMAL_MODE=pseudo             # typed | anon | pseudo | mask | hash

# ── Misc ─────────────────────────────────────────────────────────────────────
# PRESENTON_HTTP_HOST_PORT=5001    # host port (Docker Compose only; container listens on 80)
# CAN_CHANGE_KEYS=true             # false = lock API keys so the UI can't edit them
# DISABLE_ANONYMOUS_TRACKING=true  # disable the upstream's anonymous telemetry
